# Wanderlearn Stories — environment variables
#
# Copy to `.env.local` and fill in values. Never commit `.env*` files
# with real values. The canonical list lives in local plans 04 and 10.
#
# After /vercel:bootstrap runs, you can populate most of this with:
#   vercel env pull .env.local

# ---------------------------------------------------------------------
# Database (Neon Postgres) — auto-provisioned by /vercel:bootstrap
# ---------------------------------------------------------------------
DATABASE_URL=

# ---------------------------------------------------------------------
# Better Auth — generate secret with `openssl rand -base64 32`
# ---------------------------------------------------------------------
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://stories.wanderlearn.witus.online

# ---------------------------------------------------------------------
# FlashLearn-AI HTTP API (plan 02 / 08)
# Spaced-repetition + next-day comprehension webhook.
# ---------------------------------------------------------------------
FLASHLEARN_API_BASE=
FLASHLEARN_API_KEY=

# ---------------------------------------------------------------------
# Cloudinary (shared WitUS tenant) — audio + image assets
# ---------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------------------------------------------------------------------
# Mailgun — parent-consent emails, child-data export, FL-AI next-day prompts
# ---------------------------------------------------------------------
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ---------------------------------------------------------------------
# Public-bound config (NEXT_PUBLIC_* is exposed to the client)
# ---------------------------------------------------------------------
NEXT_PUBLIC_PUBLIC_URL=https://stories.wanderlearn.witus.online
NEXT_PUBLIC_PARENT_GATE_AGE=13
